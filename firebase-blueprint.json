{
  "entities": {
    "pothole": {
      "title": "Pothole",
      "description": "A detected pothole with location and metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "reportImageUrl": { "type": "string" },
        "resolvedImageUrl": { "type": "string" },
        "userId": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["latitude", "longitude", "timestamp", "userId"]
    },
    "user": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "municipal"] }
      },
      "required": ["uid", "email"]
    },
    "permitted_user": {
      "title": "Permitted User",
      "description": "A user email permitted to have a specific role.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "municipal"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/potholes/{potholeId}": {
      "schema": "pothole",
      "description": "Collection of all detected potholes."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles."
    },
    "/permitted_users/{email}": {
      "schema": "permitted_user",
      "description": "List of emails with assigned roles."
    }
  }
}
