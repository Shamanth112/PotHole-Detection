{
  "entities": {
    "pothole": {
      "title": "Pothole",
      "description": "A reported pothole in the system.",
      "type": "object",
      "properties": {
        "latitude": { "type": "number", "description": "Latitude of the pothole." },
        "longitude": { "type": "number", "description": "Longitude of the pothole." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the pothole was reported." },
        "severity": { "type": "string", "enum": ["low", "medium", "high"], "description": "Severity of the pothole." },
        "reportImageUrl": { "type": "string", "format": "uri", "description": "URL of the report image." },
        "resolvedImageUrl": { "type": "string", "format": "uri", "description": "URL of the resolved image." },
        "userId": { "type": "string", "description": "UID of the user who reported it." },
        "userName": { "type": "string", "description": "Display name of the user." },
        "address": { "type": "string", "description": "Address or description of the location." },
        "status": { "type": "string", "enum": ["reported", "verified", "fixing", "resolved"], "description": "Current status of the pothole." },
        "notes": { "type": "string", "description": "Additional notes about the pothole." }
      },
      "required": ["latitude", "longitude", "timestamp", "userId"]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "Profile information for a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique ID of the user." },
        "displayName": { "type": "string", "description": "Display name of the user." },
        "email": { "type": "string", "format": "email", "description": "Email address of the user." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL of the user's profile photo." },
        "role": { "type": "string", "enum": ["user", "admin", "municipal"], "description": "Role of the user in the system." }
      },
      "required": ["uid", "email", "role"]
    },
    "permittedUser": {
      "title": "Permitted User",
      "description": "A user pre-authorized with a specific role.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "Email address of the permitted user." },
        "role": { "type": "string", "enum": ["user", "admin", "municipal"], "description": "Role assigned to this email." }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/potholes/{potholeId}": {
      "schema": "pothole",
      "description": "Collection of all pothole reports."
    },
    "/users/{uid}": {
      "schema": "userProfile",
      "description": "Collection of user profiles."
    },
    "/permitted_users/{email}": {
      "schema": "permittedUser",
      "description": "Collection of pre-authorized users."
    }
  }
}
